# Conexión a la base de Atlas (modelo federado: base propia, autónoma).
# Copiá este archivo a .env y ajustá si hace falta.

POSTGRES_DB=atlas
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas
POSTGRES_PORT=5432

# DSN async (usa asyncpg). Apunta al Postgres del docker-compose.
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas

# Base exclusiva para pytest — nunca toca la base de dev.
DATABASE_URL_TEST=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas_test
