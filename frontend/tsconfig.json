{
  "compilerOptions": {
    "target":        "ES2022",
    "module":        "ESNext",
    "moduleResolution": "bundler",
    "lib":           ["ES2022", "DOM", "DOM.Iterable"],
    "outDir":        "./dist",
    "rootDir":       ".",
    "strict":        true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck":  true
  },
  "include": ["*.ts"],
  "exclude": ["dist", "node_modules"]
}
